generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String
  saved    SavedCollege[]
}

model SavedCollege {
  id       Int    @id @default(autoincrement())
  name     String
  location String
  fees     Int     // ✅ FIXED (number)
  rating   Float
  userId   Int
  user     User   @relation(fields: [userId], references: [id])

  @@unique([name, userId])
}